Usage:
  nx url [text...]
  nx url -d [url-encoded...]
  nx url decode [url-encoded...]

Example:
  nx url "a b+c"
  nx url -d "a%20b%2Bc"

Default mode is encode.
EOF
}

mode=enc
case "${1:-}" in
  -h|--help|help)
    usage
    exit 0
    ;;
  -d|--decode|dec|decode)
    mode=dec
